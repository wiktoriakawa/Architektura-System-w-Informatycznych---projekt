# Wymuś końcówki linii LF dla wszystkich plików tekstowych — bash i Python
# w kontenerach Linuxowych nie tolerują CRLF.
* text=auto eol=lf

# Skrypty bash i konfiguracje — zawsze LF, niezależnie od systemu.
*.sh   text eol=lf
*.py   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.ini  text eol=lf
*.conf text eol=lf
Dockerfile text eol=lf
.env*  text eol=lf

# Pliki binarne — nie ruszaj.
*.png binary
*.jpg binary
*.pdf binary
