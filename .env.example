# ============================================
# TrendEconomy — zmienne środowiskowe
# Skopiuj do .env i dostosuj wartości
# ============================================

# PostgreSQL
POSTGRES_USER=trendeconomy
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=trendeconomy_db

# Backend
DATABASE_URL=postgresql://trendeconomy:secretpassword@db:5432/trendeconomy_db
LOG_LEVEL=INFO

# Frontend
VITE_API_URL=http://localhost:8000
